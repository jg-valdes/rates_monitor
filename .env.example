# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

DEBUG=1

# Comma-separated domains the server responds to (required when DEBUG=False)
ALLOWED_HOSTS=yourdomain.com

# Comma-separated origins for CSRF validation (must match what Caddy uses)
CSRF_TRUSTED_ORIGINS_EXTRA=yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
# Passcode shown on the login page. Leave empty to disable the gate (dev only).
ACCESS_PASSCODE=

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the token.
# Get the chat ID by sending a message to the bot and reading:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Both must be set for alerts to be sent. Leave empty to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
# Directory where db.sqlite3 is stored.
# Docker Compose sets this automatically via the `environment` block.
# Leave empty for local development (defaults to project root).
DATA_DIR=data

# for access django admin panel, set these environment variables or create a superuser with `python manage.py createsuperuser`
DJANGO_SUPERUSER_USERNAME=username
DJANGO_SUPERUSER_EMAIL=useremal@email.test
DJANGO_SUPERUSER_PASSWORD=strong-password